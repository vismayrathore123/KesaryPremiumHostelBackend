  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Stripe": {
    "SecretKey": "sk_test_YOUR_STRIPE_SECRET_KEY",
    "PublishableKey": "pk_test_YOUR_STRIPE_PUBLISHABLE_KEY",
    "WebhookSecret": "whsec_YOUR_WEBHOOK_SECRET"
  },
  "PayU": {
    "MerchantKey": "YOUR_PAYU_MERCHANT_KEY",
    "Salt": "YOUR_PAYU_SALT",
    "BaseUrl": "https://sandboxsecure.payu.in/_payment"
  },
  "AllowedOrigins": [ "http://localhost:3000", "http://localhost:5500", "https://kesarpremium.com" ],
  "AdminContact": {
    "Phone": "12345678",
    "WhatsApp": "9112345678",
    "Email": "admin@kesarpremium.com"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
